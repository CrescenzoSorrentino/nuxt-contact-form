# Copy this file to ".env" and fill in the real values.
# ".env" is git-ignored, so your secrets never end up in the repository.
#
# The NUXT_ prefix makes Nuxt override the matching runtimeConfig key
# (see nuxt.config.ts):
#   NUXT_RESEND_API_KEY          -> runtimeConfig.resendApiKey
#   NUXT_CONTACT_RECIPIENT_EMAIL -> runtimeConfig.contactRecipientEmail
#   NUXT_CONTACT_FROM_EMAIL      -> runtimeConfig.contactFromEmail
#   NUXT_UPSTASH_REDIS_REST_URL   -> runtimeConfig.upstashRedisRestUrl
#   NUXT_UPSTASH_REDIS_REST_TOKEN -> runtimeConfig.upstashRedisRestToken

# Resend API key (https://resend.com/api-keys)
NUXT_RESEND_API_KEY=

# Address that RECEIVES the form messages (your inbox)
NUXT_CONTACT_RECIPIENT_EMAIL=

# Sender address the email is sent FROM.
# For testing you can use onboarding@resend.dev (provided by Resend).
# In production, use an address on a domain you verified in Resend.
NUXT_CONTACT_FROM_EMAIL=onboarding@resend.dev

# Upstash Redis credentials for rate limiting (https://console.upstash.com).
# Found in your database dashboard under "REST API".
NUXT_UPSTASH_REDIS_REST_URL=
NUXT_UPSTASH_REDIS_REST_TOKEN=
